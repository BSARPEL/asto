{
  "name": "asto",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=mobile",
    "api": "npm run dev --workspace=@asto/api",
    "dev": "node scripts/dev-all.mjs",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:api": "npm run api",
    "dev:metro": "npm run mobile",
    "sync:shared": "node scripts/sync-shared.mjs",
    "sync:ios": "node scripts/sync-ios.mjs",
    "sync:ios:force": "node scripts/sync-ios.mjs --force",
    "sync:skills": "node scripts/sync-agent-skills.mjs",
    "ios:prebuild": "npm run ios:prebuild --workspace=mobile",
    "ios:open": "npm run ios:open --workspace=mobile",
    "ios:device": "npm run ios:device --workspace=mobile",
    "build:cities": "node scripts/build-world-cities.mjs",
    "deploy:firestore-rules": "node scripts/deploy-firestore-rules.mjs",
    "deploy:firestore-indexes": "node scripts/deploy-firestore-indexes.mjs",
    "db:init": "npm run db:init --workspace=@asto/api",
    "firebase:setup": "npm run sync:shared && npm run db:init && npm run deploy:firestore-rules && npm run deploy:firestore-indexes",
    "deploy:ai-api": "node scripts/deploy-ai-api.mjs",
    "setup:production": "node scripts/setup-firebase-production.mjs",
    "verify:ai-api": "node scripts/verify-ai-api.mjs",
    "verify:store": "node scripts/verify-store-build.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "ios:archive:store": "npm run verify:store && npm run ios:archive --workspace=mobile",
    "test:auth": "node scripts/test-mobile-auth-flow.mjs",
    "test:birth": "node scripts/test-birth-flow.mjs",
    "test:ai": "node scripts/test-ai-api.mjs",
    "test:journey": "node scripts/test-user-journey.mjs",
    "shared:build": "npm run build --workspace=@asto/shared",
    "postinstall": "npm run shared:build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "firebase-tools": "^15.24.0"
  }
}
