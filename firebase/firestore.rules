rules_version = '2';

// BN Astro — mobil: Firebase Auth + Firestore (bnastro)
// Schema v2: partners.relationshipType / analysisFocus / previewSummary / fullUnlocked
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function ownsResource() {
      return isAuthenticated() && resource != null && resource.data.userId == request.auth.uid;
    }

    function ownsRequest() {
      return isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    function validRelationshipType() {
      return !('relationshipType' in request.resource.data)
        || request.resource.data.relationshipType in ['love', 'friendship', 'family', 'work'];
    }

    function validPartnerCreate(partnerId) {
      return ownsRequest()
        && request.resource.data.keys().hasAll(['id', 'userId', 'birth', 'natalChart', 'createdAt'])
        && request.resource.data.id == partnerId
        && validRelationshipType()
        && (
          !('fullUnlocked' in request.resource.data)
          || request.resource.data.fullUnlocked is bool
        )
        && (
          !('analysisFocus' in request.resource.data)
          || request.resource.data.analysisFocus is string
        )
        && (
          !('previewSummary' in request.resource.data)
          || request.resource.data.previewSummary is string
        );
    }

    function validPartnerUpdate() {
      return ownsResource()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.id == resource.data.id
        && validRelationshipType()
        && (
          !('fullUnlocked' in request.resource.data)
          || request.resource.data.fullUnlocked is bool
        );
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /ledger/{entryId} {
      // get on missing doc: resource is null — still allow (returns not-found)
      allow get: if isAuthenticated() && (resource == null || ownsResource());
      allow list: if ownsResource();
      allow create: if ownsRequest();
      allow update, delete: if false;
    }

    match /adClaims/{docId} {
      // docId = {userId}_{date} — allow get before first ad claim exists
      allow get: if isAuthenticated() && docId.matches('^' + request.auth.uid + '_.+');
      allow list: if ownsResource();
      allow create, update: if ownsRequest();
    }

    match /partners/{partnerId} {
      allow read, delete: if ownsResource();
      allow create: if validPartnerCreate(partnerId);
      allow update: if validPartnerUpdate();
    }

    match /conversations/{convId} {
      allow read, update, delete: if ownsResource();
      allow create: if ownsRequest();
    }

    match /readings/{readingId} {
      allow get: if isAuthenticated() && readingId.matches('^' + request.auth.uid + '_.+');
      allow list: if ownsResource();
      allow create, update: if ownsRequest();
      allow delete: if ownsResource();
    }

    match /_meta/{doc} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // API (Admin SDK) only — client cannot access
    match /users_by_email/{email} {
      allow read, write: if false;
    }
    match /sessions/{token} {
      allow read, write: if false;
    }
  }
}
