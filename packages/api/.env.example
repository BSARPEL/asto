PORT=8788
NODE_ENV=development

# ── Google Gemini (AI API — yalnızca sunucu) ──
# Bkz. docs/SECRETS.md — Google AI Studio'dan alınır
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI (yedek)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AI_LOG_USAGE=1

# ── Firebase Admin SDK (Firestore — sunucu) ──
# İndirilen dosyayı kopyalayın:
#   cp ~/Downloads/bn-astro-firebase-adminsdk-*.json packages/api/.secrets/firebase-adminsdk.json
STORE_BACKEND=auto
FIREBASE_PROJECT_ID=bn-astro
FIREBASE_DATABASE_ID=bnastro
FIREBASE_SERVICE_ACCOUNT_PATH=.secrets/firebase-adminsdk.json

# Production: virgülle ayrılmış origin listesi (web admin vb.)
# CORS_ORIGINS=https://asto.app
