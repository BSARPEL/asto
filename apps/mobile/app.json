{
  "expo": {
    "name": "BN Astro",
    "slug": "bn-astro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bnastro",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bn.astro.app",
      "appleTeamId": "2U98475NHT",
      "deploymentTarget": "15.1",
      "infoPlist": {
        "CFBundleDisplayName": "BN Astro",
        "NSUserTrackingUsageDescription": "Kişiselleştirilmiş deneyim ve reklam ölçümü için kullanılır."
      }
    },
    "android": {
      "package": "com.bn.astro.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAF8F4",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FAF8F4"
        }
      ],
      "@react-native-community/datetimepicker",
      "./plugins/withNativeIosStandalone.js"
    ],
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "asto-local-dev"
      },
      "appEnv": "development"
    }
  }
}
