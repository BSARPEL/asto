# Yerel geliştirme
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_DATA_BACKEND=firebase

# Firebase (bn-astro) — apps/mobile/.env dosyasındaki EXPO_PUBLIC_FIREBASE_* değerlerini kopyalayın

# AI sunucusu (yerel Gemini proxy) — Mac LAN IP: ipconfig getifaddr en0
EXPO_PUBLIC_AI_API_URL=http://192.168.0.175:8788/api

# Google AI Studio — Gemini (AIzaSy… veya AQ.… formatı)
# https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash-lite
