# Fiziksel iPhone (Xcode native build) — Mac'in LAN IP'sini yazın:
# ipconfig getifaddr en0
EXPO_PUBLIC_API_URL=http://192.168.0.175:8788/api

# iOS Simülatör (Metro ile geliştirme) için boş bırakılabilir veya:
# EXPO_PUBLIC_API_URL=http://127.0.0.1:8788/api

EXPO_PUBLIC_REVENUECAT_API_KEY=
EXPO_PUBLIC_ADMOB_REWARDED_UNIT_ID=
