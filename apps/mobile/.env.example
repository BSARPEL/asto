# Yerel geliştirme
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_DATA_BACKEND=firebase

# Firebase (bn-astro) — Console → Project settings → Web app

# AI: yerel Express (önerilen) — Mac LAN IP: ipconfig getifaddr en0
EXPO_PUBLIC_AI_API_URL=http://192.168.0.175:8788/api

# Opsiyonel: doğrudan Gemini (yalnızca yerel .env — asla git'e commit etmeyin)
# EXPO_PUBLIC_GEMINI_API_KEY=
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash-lite
