# App Store / TestFlight — şablon (kopyala: cp .env.production.example .env)
EXPO_PUBLIC_APP_ENV=production
EXPO_PUBLIC_DATA_BACKEND=firebase

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=bn-astro.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=bn-astro
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=bn-astro.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_DATABASE_ID=bnastro

# Doğrudan Gemini (Cloud Functions yok) — gitignore .env; commit etme
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash-lite

EXPO_PUBLIC_REVENUECAT_API_KEY=
EXPO_PUBLIC_ADMOB_REWARDED_UNIT_ID=
